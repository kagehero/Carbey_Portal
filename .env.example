# ===========================================
# Carbey Portal - Environment Variables Template
# ===========================================
# Copy to `.env.local` for local development.

# ===========================================
# Supabase (required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# サイトURL (メールリンクの遷移先に使用)
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# SMTP (招待/パスワードリセットの自前メール送信に使用)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 送信元 (省略時は SMTP_USER)
SMTP_FROM=Carbey <no-reply@example.com>
# ポート465 のときは true
SMTP_SECURE=false

# ===========================================
# AI Providers (移植するAI機能で使用)
# ===========================================
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_GENAI_API_KEY=your_google_genai_key_here
